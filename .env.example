# BTC Bot — Environment Variables
# Copy karo: cp .env.example .env
# KABHI .env GitHub par push mat karo!

# Required
BOT_TOKEN=your_new_bot_token_here     # @BotFather se naya bot banao

# Channel jahan BTC signals jaayenge
CHANNEL_ID=@your_btc_channel          # ya -100xxxxxxxxxx format

# Tumhara Telegram User ID
ADMIN_ID=123456789

# TradingView webhook secret
TV_SECRET=rudra123

# Railway automatically set karta hai
PORT=8080
